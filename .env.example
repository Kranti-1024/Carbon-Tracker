# Copy this file to .env and fill in real values for local development.
# In production (Render/Railway), set these as actual environment variables
# in the platform dashboard — never commit a real .env file.

# ⚠️  REQUIRED: Generate a strong random key, e.g.:
#     python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Database — Railway/Render inject DATABASE_URL automatically for Postgres.
# Local SQLite fallback is used when this is absent.
DATABASE_URL=sqlite:///instance/app.db

# ⚠️  Set to redis://<host>:<port>/0 in production to share rate-limit
# counters across all gunicorn workers. memory:// only works for 1 worker.
RATELIMIT_STORAGE_URI=memory://

# Flask CLI — needed for `flask db upgrade` and `flask seed-factors`
FLASK_APP=run.py

# ⚠️  MUST be 0 in production. Setting this to 1 exposes the interactive
# Werkzeug debugger which allows arbitrary code execution.
FLASK_DEBUG=0
